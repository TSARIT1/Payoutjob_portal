# AI server port
PORT=3001

# Your own OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: override model used by AI server
OPENAI_MODEL=gpt-4o-mini

# Optional: number of top files added to AI context
AI_MAX_CONTEXT_DOCS=4

# Optional: frontend URL for AI backend
VITE_AI_SERVER_URL=http://localhost:3001
